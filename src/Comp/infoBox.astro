---
interface Props { title: string }
const { title } = Astro.props;
---
<!-- why does this have to be at the top?? -->
 <style>
    .RX_infoBox {
        position: relative;

        /* // switch to relative height when youre not a dumbass */
        width: 275px;

        border: solid 1px white;
        /* border-style: dashed; */

        background-color: rgb(0, 0, 0);

        .RX_Title {
            border-bottom:  solid 1px white;

            padding-left: 5px;
            padding-right: 5px;

            background-color: rgb(108, 108, 108);
        }

        .RX_Content {
            font-family: "Playfair Display", serif;

            color: rgb(81, 81, 81);

            padding-left: 5px;
            padding-right: 5px;
        }

        & * {
            padding: 0;
            margin: 0;
        }

        animation-name: open;
        animation-duration: 0.5s;
    }
</style>

<!-- main content -->
<div class="RX_infoBox">
    <div class="RX_Title">{title}</div>
    <div class="RX_Content">
        <slot />
    </div>
</div>