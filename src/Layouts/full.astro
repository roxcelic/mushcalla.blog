---
interface Props { title: string; desc: string; }
const { desc, title } = Astro.props;

// scss
import '../res/scss/style.scss'
---

<!doctype html>
<html lang="en">
	<head>
        <!--Webpage data-->
        <!---------------->
		<meta charset="UTF-8" />
		<meta name="description" content={ desc }/>
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/x-icon" href="/favicon.ico">

        <meta name="generator" content={Astro.generator} />
		<title>{ title }</title>
        <!---------------->

        <!--Fonts (all from google i think)-->
        <!----------------------------------->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Dosis:wght@200..800&family=Pixelify+Sans:wght@400..700&display=swap" rel="stylesheet">
        <link href="https://fonts.googleapis.com/css2?family=Bitcount+Grid+Double+Ink:wght@100..900&family=Dosis:wght@200..800&family=M+PLUS+Rounded+1c&family=Pixelify+Sans:wght@400..700&display=swap" rel="stylesheet">
		<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0&icon_names=send" />
        <link href="https://fonts.googleapis.com/css2?family=Bitcount+Grid+Double+Ink:wght@100..900&family=Dosis:wght@200..800&family=M+PLUS+Rounded+1c&family=Pixelify+Sans:wght@400..700&family=VT323&display=swap" rel="stylesheet">
        
        <!----------------------------------->

        <!--my stuff-->
        <!------------>
        <script src="../res/scripts/script.js"/>
        <!------------>
	</head>
	<body>
        <main>
            <!--page specific content-->
            <!------------------------->
            <slot />
            <!------------------------->
        </main>
	</body>
</html>